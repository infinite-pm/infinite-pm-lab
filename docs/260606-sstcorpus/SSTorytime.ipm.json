      "alias": "",
      "type": "Concept"
    },
    {
      "id": 6,
      "name": "A graph is basically a structure with an index at every node. There are two modes of use: random access lookup for starting a search--which SQL is already good at, and exploring, path tracing, following leads from that starting point like hypertext.",
      "alias": "",
      "type": "Event"
    },
    {
      "id": 7,
      "name": "A recursive search in SQL",
      "alias": "",
      "type": "Thing"
    },
    {
      "id": 8,
