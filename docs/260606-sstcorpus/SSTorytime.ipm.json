    {
      "id": 2,
      "name": "%\"Longer phrases\" used a limited number of times are common concepts",
      "alias": "",
      "type": "Thing",
      "tooltip": "%\"Longer phrases\" are easier to write than short precise phrases, so people need help to break them down and summarize their intent"
    },
    {
      "id": 3,
      "name": "%\"Short phrases\" used once are usually unique names i.e. a %\"proper name\"",
      "alias": "",
      "type": "Thing"
    },
